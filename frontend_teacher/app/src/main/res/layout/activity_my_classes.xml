<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3F72AF"
    tools:context=".MyClassesActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnMenuCard"
        android:layout_width="55dp"
        android:layout_height="50dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="24dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/open_menu"
        app:cardBackgroundColor="@color/steel_blue"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/blue_sky"
        app:strokeWidth="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Icon Menu"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_menu"
            app:tint="@color/ivory" />
    </com.google.android.material.card.MaterialCardView>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnMenuCard">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:contentDescription="Logo"
            android:src="@drawable/ic_learning_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="@string/title"
            android:textColor="@color/ivory"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgLogo"
            app:layout_constraintTop_toTopOf="@id/imgLogo"
            app:layout_constraintBottom_toBottomOf="@id/imgLogo"/>
    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="#DBE2EF"
        app:cardElevation="0dp"
        app:shapeAppearanceOverlay="@style/TopRoundedCard"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="60dp"
                app:cardBackgroundColor="@color/ivory"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:id="@+id/icSearch"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_search"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/blue" />

                    <EditText
                        android:id="@+id/edtSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/search_course"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/dark_blue"
                        android:textColorHint="@color/blue_charcoal"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@id/icFilter"
                        app:layout_constraintStart_toEndOf="@id/icSearch" />

                    <ImageView
                        android:id="@+id/icFilter"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_menu"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/dark_blue" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtListTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/list_courses"
                android:textColor="@color/dark_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/btnAddCourse"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/searchContainer" />

            <!-- ADD BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddCourse"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:paddingHorizontal="12dp"
                android:text="@string/btn_course"
                android:textAllCaps="false"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/light_blue"
                app:cornerRadius="20dp"
                app:layout_constraintBaseline_toBaselineOf="@id/txtListTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCourseList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingBottom="32dp"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="true"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/txtListTitle"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_course_list"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgCenterIcon"
        android:layout_width="124dp"
        android:layout_height="103dp"
        android:background="@color/soft_blue"
        android:padding="22dp"
        android:src="@drawable/ic_book"
        android:elevation="10dp"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:tint="@color/ivory"
        app:layout_constraintBottom_toTopOf="@id/mainCard"
        app:layout_constraintTop_toTopOf="@id/mainCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>




