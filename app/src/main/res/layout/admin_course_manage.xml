<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminManageCourse">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#3F72AF">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMenuCard"
            android:layout_width="55dp"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Mở menu điều hướng"
            app:cardBackgroundColor="#2A528A"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="#567EBB"
            app:strokeWidth="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_menu"
                android:contentDescription="Icon Menu"
                app:tint="#F9F7F7" />
        </com.google.android.material.card.MaterialCardView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnMenuCard">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_learning_logo"
                android:contentDescription="Logo ứng dụng"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Learning course"
                android:textColor="#F9F7F7"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/imgLogo"
                app:layout_constraintTop_toTopOf="@id/imgLogo"
                app:layout_constraintBottom_toBottomOf="@id/imgLogo" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="50dp"
            app:cardBackgroundColor="#DBE2EF"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/headerContainer"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/searchContainer"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="60dp"
                    app:cardBackgroundColor="#F9F7F7"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:id="@+id/icSearch"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_search"
                            app:tint="#3F72AF"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <EditText
                            android:id="@+id/edtSearch"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="Tìm kiếm khóa học..."
                            android:paddingHorizontal="12dp"
                            android:textColor="#112D4E"
                            android:textColorHint="#88112D4E"
                            android:textSize="16sp"
                            app:layout_constraintStart_toEndOf="@id/icSearch"
                            app:layout_constraintEnd_toStartOf="@id/icFilter" />

                        <ImageView
                            android:id="@+id/icFilter"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_menu"
                            app:tint="#112D4E"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/txtListTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Danh sách khóa học"
                    android:textColor="#112D4E"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/searchContainer"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/txtEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Không có khóa học cần duyệt"
                    android:textColor="#112D4E"
                    android:textSize="16sp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/txtListTitle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCourseList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:paddingBottom="24dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/txtListTitle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:listitem="@layout/admin_course_summary" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imgCenterIcon"
            android:layout_width="80dp"
            android:layout_height="60dp"
            app:cardBackgroundColor="#7895CB"
            app:cardCornerRadius="60dp"
            app:cardElevation="10dp"
            app:layout_constraintTop_toTopOf="@id/mainCard"
            app:layout_constraintBottom_toTopOf="@id/mainCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="7dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_book"
                android:contentDescription="@string/desc_book_icon"
                app:tint="#F9F7F7" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/sidebarLayout"
        layout="@layout/admin_layout_sidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end" />

</androidx.drawerlayout.widget.DrawerLayout>
